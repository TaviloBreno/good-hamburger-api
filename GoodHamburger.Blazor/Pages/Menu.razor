@page "/menu"

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">📋 Cardápio</h2>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">🍔 Sanduíches</h4>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h6 class="mb-0">X Burger</h6>
                            <small class="text-muted">Hambúrguer com queijo</small>
                        </div>
                        <span class="badge bg-primary">R$ 5,00</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h6 class="mb-0">X Egg</h6>
                            <small class="text-muted">Hambúrguer com ovo e queijo</small>
                        </div>
                        <span class="badge bg-primary">R$ 4,50</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h6 class="mb-0">X Bacon</h6>
                            <small class="text-muted">Hambúrguer com bacon e queijo</small>
                        </div>
                        <span class="badge bg-primary">R$ 7,00</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">🍟 Acompanhamentos</h4>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h6 class="mb-0">Batata Frita</h6>
                            <small class="text-muted">Batata frita crocante</small>
                        </div>
                        <span class="badge bg-primary">R$ 2,00</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">🥤 Bebidas</h4>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h6 class="mb-0">Refrigerante</h6>
                            <small class="text-muted">Lata 350ml</small>
                        </div>
                        <span class="badge bg-primary">R$ 2,50</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">🎯 Regras de Desconto</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <div class="card">
                                <div class="card-body">
                                    <h6 class="card-title">Combo Good</h6>
                                    <p class="card-text small">Sanduíche + Batata + Refrigerante</p>
                                    <span class="badge bg-success">20% OFF</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="card">
                                <div class="card-body">
                                    <h6 class="card-title">Promoção Drink</h6>
                                    <p class="card-text small">Sanduíche + Refrigerante</p>
                                    <span class="badge bg-success">15% OFF</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="card">
                                <div class="card-body">
                                    <h6 class="card-title">Promoção Side</h6>
                                    <p class="card-text small">Sanduíche + Batata</p>
                                    <span class="badge bg-success">10% OFF</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>