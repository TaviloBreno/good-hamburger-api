@page "/"
@using GoodHamburger.Core.DTOs
@using GoodHamburger.Core.Entities
@inject HttpClient Http
@inject IJSRuntime JS

<div class="gh-page">
    <section class="gh-hero">
        <div class="gh-hero__content">
            <p class="gh-eyebrow">Painel de Operacao</p>
            <h1>Good Hamburger</h1>
            <p class="gh-subtitle">Registre pedidos em segundos e acompanhe faturamento em tempo real.</p>

            <div class="gh-kpis">
                <article class="gh-kpi-card">
                    <span>Pedidos</span>
                    <strong>@GetOrdersCount()</strong>
                </article>
                <article class="gh-kpi-card">
                    <span>Faturamento</span>
                    <strong>@GetRevenue().ToString("C")</strong>
                </article>
                <article class="gh-kpi-card">
                    <span>Ticket medio</span>
                    <strong>@GetAverageTicket().ToString("C")</strong>
                </article>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(feedbackMessage))
    {
        <div class="gh-feedback gh-feedback--@feedbackType">
            <span>@feedbackMessage</span>
            <button class="gh-feedback__close" @onclick="ClearMessage" aria-label="Fechar">x</button>
        </div>
    }

    <section class="gh-grid">
        <article class="gh-card gh-card--composer" id="composer">
            <div class="gh-card__header">
                <h2>@(isEditing ? "Editar Pedido" : "Novo Pedido")</h2>
                <p>Monte o combo e confira os descontos automaticamente.</p>
            </div>

            <div class="gh-form-group">
                <label for="sandwich">Sanduiche <span>*</span></label>
                <select id="sandwich" @bind="selectedSandwich" class="gh-select">
                    <option value="">Selecione...</option>
                    @foreach (var sandwich in sandwiches)
                    {
                        <option value="@sandwich.Key">@sandwich.Value</option>
                    }
                </select>
            </div>

            <div class="gh-form-group">
                <label for="side">Acompanhamento</label>
                <select id="side" @bind="selectedSide" class="gh-select">
                    <option value="">Nenhum</option>
                    @foreach (var side in sideDishes)
                    {
                        <option value="@side.Key">@side.Value</option>
                    }
                </select>
            </div>

            <div class="gh-form-group">
                <label for="drink">Bebida</label>
                <select id="drink" @bind="selectedDrink" class="gh-select">
                    <option value="">Nenhuma</option>
                    @foreach (var drink in drinks)
                    {
                        <option value="@drink.Key">@drink.Value</option>
                    }
                </select>
            </div>

            <div class="gh-preview">
                <h3>Resumo financeiro</h3>
                <div class="gh-preview__row">
                    <span>Subtotal</span>
                    <strong>@GetSubtotal().ToString("C")</strong>
                </div>
                <div class="gh-preview__row">
                    <span>Desconto</span>
                    <strong class="gh-money--discount">-@GetDiscount().ToString("C")</strong>
                </div>
                <div class="gh-preview__row gh-preview__row--total">
                    <span>Total</span>
                    <strong>@GetTotal().ToString("C")</strong>
                </div>
            </div>

            <div class="gh-actions">
                <button class="gh-btn gh-btn--primary" @onclick="CreateOrder" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span>Salvando...</span>
                    }
                    else if (isEditing)
                    {
                        <span>Atualizar pedido</span>
                    }
                    else
                    {
                        <span>Criar pedido</span>
                    }
                </button>

                @if (isEditing)
                {
                    <button class="gh-btn gh-btn--ghost" @onclick="ResetForm" disabled="@isLoading">Cancelar edicao</button>
                }
            </div>
        </article>

        <article class="gh-card gh-card--orders">
            <div class="gh-card__header gh-card__header--inline">
                <div>
                    <h2>Pedidos recentes</h2>
                    <p>Visao consolidada de vendas e descontos aplicados.</p>
                </div>
                <button class="gh-btn gh-btn--ghost" @onclick="LoadOrders" disabled="@isLoadingOrders">Atualizar</button>
            </div>

            @if (isLoadingOrders)
            {
                <div class="gh-loading">
                    <div class="spinner-border" role="status"></div>
                    <span>Carregando pedidos...</span>
                </div>
            }
            else if (orders == null || !orders.Any())
            {
                <div class="gh-empty">
                    <h3>Nenhum pedido ainda</h3>
                    <p>Crie o primeiro pedido para iniciar o painel.</p>
                </div>
            }
            else
            {
                <div class="gh-table-wrap">
                    <table class="gh-table">
                        <thead>
                            <tr>
                                <th>Pedido</th>
                                <th>Data</th>
                                <th>Itens</th>
                                <th>Subtotal</th>
                                <th>Desconto</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in orders)
                            {
                                <tr>
                                    <td>
                                        <code>@order.Id.ToString()[..8]</code>
                                    </td>
                                    <td>@order.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                                    <td>
                                        <div class="gh-item-stack">
                                            <span>@GetSandwichName(order.Sandwich)</span>
                                            <small>@(GetSideName(order.SideDish)) | @(GetDrinkName(order.Drink))</small>
                                        </div>
                                    </td>
                                    <td>@order.Subtotal.ToString("C")</td>
                                    <td>
                                        <span class="gh-discount-chip">-@order.Discount.ToString("C")</span>
                                    </td>
                                    <td class="gh-total-cell">@order.Total.ToString("C")</td>
                                    <td class="gh-row-actions">
                                        <button class="gh-icon-btn" title="Editar" @onclick="() => EditOrder(order)">Editar</button>
                                        <button class="gh-icon-btn gh-icon-btn--danger" title="Excluir" @onclick="() => DeleteOrder(order.Id)">Excluir</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>
    </section>
</div>

@code {
    private Dictionary<string, string> sandwiches = new()
    {
        { "XBurger", "X Burger - R$ 5,00" },
        { "XEgg", "X Egg - R$ 4,50" },
        { "XBacon", "X Bacon - R$ 7,00" }
    };

    private Dictionary<string, string> sideDishes = new()
    {
        { "Fries", "Batata Frita - R$ 2,00" }
    };

    private Dictionary<string, string> drinks = new()
    {
        { "Soda", "Refrigerante - R$ 2,50" }
    };

    private string? selectedSandwich;
    private string? selectedSide;
    private string? selectedDrink;
    private bool isLoading = false;
    private bool isLoadingOrders = true;
    private List<OrderResponse>? orders;
    private bool isEditing = false;
    private Guid editingOrderId;
    private string? feedbackMessage;
    private string feedbackType = "info";

    private int GetOrdersCount() => orders?.Count ?? 0;

    private decimal GetRevenue() => orders?.Sum(order => order.Total) ?? 0m;

    private decimal GetAverageTicket()
    {
        if (orders == null || orders.Count == 0)
            return 0m;

        return orders.Average(order => order.Total);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        isLoadingOrders = true;
        try
        {
            orders = await Http.GetFromJsonAsync<List<OrderResponse>>("api/orders");
        }
        catch
        {
            await ShowMessage("Nao foi possivel carregar pedidos no momento.", "error");
            orders = new List<OrderResponse>();
        }
        finally
        {
            isLoadingOrders = false;
            StateHasChanged();
        }
    }

    private void EditOrder(OrderResponse order)
    {
        isEditing = true;
        editingOrderId = order.Id;
        selectedSandwich = order.Sandwich.ToString();
        selectedSide = order.SideDish?.ToString();
        selectedDrink = order.Drink?.ToString();

        _ = JS.InvokeVoidAsync("gh.scrollToComposer");
    }

    private async Task CreateOrder()
    {
        if (string.IsNullOrEmpty(selectedSandwich))
        {
            await ShowMessage("Selecione um sanduiche para continuar.", "error");
            return;
        }

        isLoading = true;
        try
        {
            var sandwich = Enum.Parse<SandwichType>(selectedSandwich);
            var side = !string.IsNullOrEmpty(selectedSide) ? Enum.Parse<SideDishType>(selectedSide) : (SideDishType?)null;
            var drink = !string.IsNullOrEmpty(selectedDrink) ? Enum.Parse<DrinkType>(selectedDrink) : (DrinkType?)null;

            if (isEditing)
            {
                var updateRequest = new UpdateOrderRequest(
                    sandwich,
                    side,
                    drink,
                    SandwichQuantity: 1,
                    SideDishQuantity: side is null ? null : 1,
                    DrinkQuantity: drink is null ? null : 1);

                var response = await Http.PutAsJsonAsync($"api/orders/{editingOrderId}", updateRequest);

                if (response.IsSuccessStatusCode)
                {
                    await ShowMessage("Pedido atualizado com sucesso.", "success");
                    ResetForm();
                    await LoadOrders();
                }
                else
                {
                    await ShowMessage(await ParseApiError(response), "error");
                }
            }
            else
            {
                var createRequest = new CreateOrderRequest(
                    sandwich,
                    side,
                    drink,
                    SandwichQuantity: 1,
                    SideDishQuantity: side is null ? null : 1,
                    DrinkQuantity: drink is null ? null : 1);

                var response = await Http.PostAsJsonAsync("api/orders", createRequest);

                if (response.IsSuccessStatusCode)
                {
                    await ShowMessage("Pedido criado com sucesso.", "success");
                    ResetForm();
                    await LoadOrders();
                }
                else
                {
                    await ShowMessage(await ParseApiError(response), "error");
                }
            }
        }
        catch (Exception ex)
        {
            await ShowMessage($"Erro: {ex.Message}", "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteOrder(Guid id)
    {
        if (await ShowConfirm("Deseja realmente excluir este pedido?"))
        {
            try
            {
                var response = await Http.DeleteAsync($"api/orders/{id}");
                if (response.IsSuccessStatusCode)
                {
                    await ShowMessage("Pedido removido com sucesso.", "success");
                    await LoadOrders();

                    if (isEditing && editingOrderId == id)
                        ResetForm();
                }
                else
                {
                    await ShowMessage(await ParseApiError(response), "error");
                }
            }
            catch (Exception ex)
            {
                await ShowMessage($"Erro: {ex.Message}", "error");
            }
        }
    }

    private void ResetForm()
    {
        isEditing = false;
        editingOrderId = Guid.Empty;
        selectedSandwich = null;
        selectedSide = null;
        selectedDrink = null;
        StateHasChanged();
    }

    private void ClearMessage()
    {
        feedbackMessage = null;
    }

    private decimal GetSandwichPrice(string sandwich)
    {
        return sandwich switch
        {
            "XBurger" => 5.00m,
            "XEgg" => 4.50m,
            "XBacon" => 7.00m,
            _ => 0
        };
    }

    private decimal GetSubtotal()
    {
        decimal total = 0;
        total += GetSandwichPrice(selectedSandwich ?? string.Empty);
        if (selectedSide == "Fries")
            total += 2.00m;
        if (selectedDrink == "Soda")
            total += 2.50m;
        return total;
    }

    private decimal GetDiscount()
    {
        bool hasSide = selectedSide == "Fries";
        bool hasDrink = selectedDrink == "Soda";
        decimal subtotal = GetSubtotal();

        if (hasSide && hasDrink)
            return subtotal * 0.20m;
        if (hasDrink)
            return subtotal * 0.15m;
        if (hasSide)
            return subtotal * 0.10m;

        return 0;
    }

    private decimal GetTotal() => GetSubtotal() - GetDiscount();

    private string GetSandwichName(SandwichType type) => type switch
    {
        SandwichType.XBurger => "X Burger",
        SandwichType.XEgg => "X Egg",
        SandwichType.XBacon => "X Bacon",
        _ => type.ToString()
    };

    private string GetSideName(SideDishType? type)
    {
        if (!type.HasValue)
            return "Sem acompanhamento";

        return type.Value switch
        {
            SideDishType.Fries => "Batata frita",
            _ => type.Value.ToString()
        };
    }

    private string GetDrinkName(DrinkType? type)
    {
        if (!type.HasValue)
            return "Sem bebida";

        return type.Value switch
        {
            DrinkType.Soda => "Refrigerante",
            _ => type.Value.ToString()
        };
    }

    private async Task ShowMessage(string message, string type)
    {
        feedbackMessage = message;
        feedbackType = type;
        StateHasChanged();

        await Task.Delay(4500);

        if (feedbackMessage == message)
            feedbackMessage = null;
    }

    private async Task<bool> ShowConfirm(string message)
    {
        return await JS.InvokeAsync<bool>("gh.confirmAction", message);
    }

    private static async Task<string> ParseApiError(HttpResponseMessage response)
    {
        var content = await response.Content.ReadAsStringAsync();

        if (string.IsNullOrWhiteSpace(content))
            return $"Erro na requisicao ({(int)response.StatusCode}).";

        try
        {
            using var doc = JsonDocument.Parse(content);
            var root = doc.RootElement;

            if (root.TryGetProperty("error", out var errorElement))
                return errorElement.GetString() ?? "Erro inesperado na API.";

            if (root.TryGetProperty("message", out var messageElement))
                return messageElement.GetString() ?? "Erro inesperado na API.";
        }
        catch
        {
            return content;
        }

        return content;
    }
}