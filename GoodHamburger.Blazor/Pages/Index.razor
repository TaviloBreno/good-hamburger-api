@page "/"
@using GoodHamburger.Core.DTOs
@using GoodHamburger.Core.Entities
@inject HttpClient Http

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
                <div class="container-fluid">
                    <a class="navbar-brand" href="/">🍔 Good Hamburger</a>
                </div>
            </nav>
        </div>
    </div>
    
    <div class="row">
        <div class="col-12">
            <div class="container mt-4">
                <div class="row">
                    <div class="col-12 text-center mb-4">
                        <h1 class="display-4">🍔 Good Hamburger</h1>
                        <p class="lead">Sistema de Pedidos - Peça seu lanche com desconto!</p>
                        <hr />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-5 mb-4">
                        <div class="card shadow-sm">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0">🆕 Novo Pedido</h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">🍔 Sanduíche *</label>
                                    <select @bind="selectedSandwich" class="form-control">
                                        <option value="">Selecione...</option>
                                        @foreach (var sandwich in sandwiches)
                                        {
                                            <option value="@sandwich.Key">@sandwich.Value</option>
                                        }
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">🍟 Acompanhamento</label>
                                    <select @bind="selectedSide" class="form-control">
                                        <option value="">Nenhum</option>
                                        @foreach (var side in sideDishes)
                                        {
                                            <option value="@side.Key">@side.Value</option>
                                        }
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">🥤 Bebida</label>
                                    <select @bind="selectedDrink" class="form-control">
                                        <option value="">Nenhuma</option>
                                        @foreach (var drink in drinks)
                                        {
                                            <option value="@drink.Key">@drink.Value</option>
                                        }
                                    </select>
                                </div>

                                @if (!string.IsNullOrEmpty(selectedSandwich))
                                {
                                    <div class="alert alert-info">
                                        <strong>📊 Prévia do Pedido:</strong><br />
                                        Subtotal: <strong>@GetSubtotal().ToString("C")</strong><br />
                                        Desconto: <strong class="text-success">-@GetDiscount().ToString("C")</strong><br />
                                        <strong class="text-danger">Total: @GetTotal().ToString("C")</strong>
                                    </div>
                                }

                                <button class="btn btn-primary w-100" @onclick="CreateOrder" disabled="@isLoading">
                                    @if (isLoading)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Processando...</span>
                                    }
                                    else
                                    {
                                        <span>Criar Pedido</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-7">
                        <div class="card shadow-sm">
                            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">📋 Pedidos Realizados</h5>
                                <button class="btn btn-light btn-sm" @onclick="LoadOrders">🔄 Atualizar</button>
                            </div>
                            <div class="card-body">
                                @if (isLoadingOrders)
                                {
                                    <div class="text-center py-5">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Carregando...</span>
                                        </div>
                                    </div>
                                }
                                else if (orders == null || !orders.Any())
                                {
                                    <div class="alert alert-info text-center">
                                        Nenhum pedido encontrado. Crie seu primeiro pedido!
                                    </div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>ID</th>
                                                    <th>Data</th>
                                                    <th>Sanduíche</th>
                                                    <th>Acompanhamento</th>
                                                    <th>Bebida</th>
                                                    <th>Subtotal</th>
                                                    <th>Desconto</th>
                                                    <th>Total</th>
                                                    <th>Ações</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var order in orders)
                                                {
                                                    <tr>
                                                        <td><code>@order.Id.ToString().Substring(0,8)...</code></td>
                                                        <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                                        <td>@GetSandwichName(order.Sandwich)</td>
                                                        <td>@(order.SideDish?.ToString() ?? "-")</td>
                                                        <td>@(order.Drink?.ToString() ?? "-")</td>
                                                        <td>@order.Subtotal.ToString("C")</td>
                                                        <td class="text-success">-@order.Discount.ToString("C")</td>
                                                        <td class="fw-bold">@order.Total.ToString("C")</td>
                                                        <td>
                                                            <button class="btn btn-sm btn-warning me-1" @onclick="() => EditOrder(order)">
                                                                ✏️
                                                            </button>
                                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteOrder(order.Id)">
                                                                🗑️
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // Dados do cardápio
    private Dictionary<string, string> sandwiches = new()
    {
        { "XBurger", "X Burger - R$ 5,00" },
        { "XEgg", "X Egg - R$ 4,50" },
        { "XBacon", "X Bacon - R$ 7,00" }
    };

    private Dictionary<string, string> sideDishes = new()
    {
        { "Fries", "Batata Frita - R$ 2,00" }
    };

    private Dictionary<string, string> drinks = new()
    {
        { "Soda", "Refrigerante - R$ 2,50" }
    };

    // Variáveis do formulário
    private string? selectedSandwich;
    private string? selectedSide;
    private string? selectedDrink;
    private bool isLoading = false;
    private bool isLoadingOrders = true;
    private List<OrderResponse>? orders;
    
    // Modo de edição
    private bool isEditing = false;
    private Guid editingOrderId;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        isLoadingOrders = true;
        try
        {
            orders = await Http.GetFromJsonAsync<List<OrderResponse>>("api/orders");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar pedidos: {ex.Message}");
            orders = new List<OrderResponse>();
        }
        finally
        {
            isLoadingOrders = false;
            StateHasChanged();
        }
    }

    private void EditOrder(OrderResponse order)
    {
        isEditing = true;
        editingOrderId = order.Id;
        selectedSandwich = order.Sandwich.ToString();
        selectedSide = order.SideDish?.ToString();
        selectedDrink = order.Drink?.ToString();
        
        // Scroll para o formulário
        StateHasChanged();
    }

    private async Task CreateOrder()
    {
        if (string.IsNullOrEmpty(selectedSandwich))
        {
            await ShowMessage("Selecione um sanduíche!", "error");
            return;
        }

        isLoading = true;
        try
        {
            var sandwich = Enum.Parse<SandwichType>(selectedSandwich);
            var side = !string.IsNullOrEmpty(selectedSide) ? Enum.Parse<SideDishType>(selectedSide) : (SideDishType?)null;
            var drink = !string.IsNullOrEmpty(selectedDrink) ? Enum.Parse<DrinkType>(selectedDrink) : (DrinkType?)null;

            if (isEditing)
            {
                // Atualizar pedido existente
                var updateRequest = new UpdateOrderRequest(sandwich, side, drink);
                var response = await Http.PutAsJsonAsync($"api/orders/{editingOrderId}", updateRequest);
                
                if (response.IsSuccessStatusCode)
                {
                    await ShowMessage("Pedido atualizado com sucesso!", "success");
                    ResetForm();
                    await LoadOrders();
                }
                else
                {
                    await ShowMessage("Erro ao atualizar pedido", "error");
                }
            }
            else
            {
                // Criar novo pedido
                var createRequest = new CreateOrderRequest(sandwich, side, drink);
                var response = await Http.PostAsJsonAsync("api/orders", createRequest);
                
                if (response.IsSuccessStatusCode)
                {
                    await ShowMessage("Pedido criado com sucesso!", "success");
                    ResetForm();
                    await LoadOrders();
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    await ShowMessage($"Erro: {error}", "error");
                }
            }
        }
        catch (Exception ex)
        {
            await ShowMessage($"Erro: {ex.Message}", "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteOrder(Guid id)
    {
        if (await ShowConfirm("Tem certeza que deseja excluir este pedido?"))
        {
            try
            {
                var response = await Http.DeleteAsync($"api/orders/{id}");
                if (response.IsSuccessStatusCode)
                {
                    await ShowMessage("Pedido removido com sucesso!", "success");
                    await LoadOrders();
                    
                    if (isEditing && editingOrderId == id)
                    {
                        ResetForm();
                    }
                }
                else
                {
                    await ShowMessage("Erro ao remover pedido", "error");
                }
            }
            catch (Exception ex)
            {
                await ShowMessage($"Erro: {ex.Message}", "error");
            }
        }
    }

    private void ResetForm()
    {
        isEditing = false;
        editingOrderId = Guid.Empty;
        selectedSandwich = null;
        selectedSide = null;
        selectedDrink = null;
        StateHasChanged();
    }

    private decimal GetSandwichPrice(string sandwich)
    {
        return sandwich switch
        {
            "XBurger" => 5.00m,
            "XEgg" => 4.50m,
            "XBacon" => 7.00m,
            _ => 0
        };
    }

    private decimal GetSubtotal()
    {
        decimal total = 0;
        total += GetSandwichPrice(selectedSandwich ?? "");
        if (selectedSide == "Fries") total += 2.00m;
        if (selectedDrink == "Soda") total += 2.50m;
        return total;
    }

    private decimal GetDiscount()
    {
        bool hasSide = selectedSide == "Fries";
        bool hasDrink = selectedDrink == "Soda";
        decimal subtotal = GetSubtotal();
        
        if (hasSide && hasDrink) return subtotal * 0.20m;
        if (hasDrink) return subtotal * 0.15m;
        if (hasSide) return subtotal * 0.10m;
        return 0;
    }

    private decimal GetTotal() => GetSubtotal() - GetDiscount();

    private string GetSandwichName(SandwichType type) => type switch
    {
        SandwichType.XBurger => "X Burger",
        SandwichType.XEgg => "X Egg",
        SandwichType.XBacon => "X Bacon",
        _ => type.ToString()
    };

    private async Task ShowMessage(string message, string type)
    {
        // Implementar toast ou alert simples
        await Task.Delay(10);
        Console.WriteLine($"[{type.ToUpper()}] {message}");
    }

    private async Task<bool> ShowConfirm(string message)
    {
        return await Task.FromResult(true);
    }
}